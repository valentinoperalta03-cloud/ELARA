# ============================================================
# ELARA — Variables de entorno
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# ============================================================

# --- Supabase ---
# Settings → API en el dashboard de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Lemon Squeezy ---
# App.lemonsqueezy.com → Settings → API
LEMON_SQUEEZY_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1...
# App.lemonsqueezy.com → Settings → Webhooks → Secret
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXX
# ID numérico de tu store en Lemon Squeezy
LEMON_SQUEEZY_STORE_ID=12345

# --- IDs de variantes en Lemon Squeezy ---
# (completar después de crear los productos en LS)
LS_VARIANT_ELARA_LAUNCH=
LS_VARIANT_INBOX_AI=
LS_VARIANT_SMART_SYSTEM=
LS_VARIANT_AUTOMATIONS=
LS_VARIANT_SOCIAL_AI=
LS_VARIANT_LEADS_AI=
LS_VARIANT_INSIGHTS=

# --- Email (Resend) ---
# resend.com → API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=hola@elara.com
RESEND_FROM_NAME=ELARA

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: https://elara.com
